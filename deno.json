{
  "$schema": "https://deno.land/x/deno/cli/schemas/config-file.v1.json",
  "name": "@danzigergeist/template-genesys-function",
  "description": "A Deno template for Genesys Cloud functions",
  "version": "0.1.0",
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.18",
    "@std/testing": "jsr:@std/testing@^1.0.17",
    "aws-lambda": "npm:@types/aws-lambda@^8.10.161",
    "purecloud-platform-client-v2": "npm:purecloud-platform-client-v2@^248.0.0"
  },
   "tasks": {
    "benchmark": {
      "description": "Run benchmarks",
      "command": "deno bench benchmarks/ --permit-no-files --quiet --allow-all"
    },
     "build:genesys": {
       "description": "Bundle function into target/index.js (CJS, non-obfuscated)",
       "command": "mkdir -p target && deno bundle --platform=deno --format=cjs src/mod.ts > target/index.js"
     },
    "build:genesys:zip": {
      "description": "Create Genesys Cloud function zip in target/index.zip",
      "dependencies": [
        "build:genesys"
      ],
      "command": "cd target && zip -qj index.zip index.js"
    },
    "clean": {
      "description": "Remove cache and generated artifacts",
      "dependencies": [
        "clean:cache",
        "clean:coverage",
        "clean:target"
      ]
    },
    "clean:cache": {
      "description": "Clear Deno cache",
      "command": "deno clean"
    },
    "clean:coverage": {
      "description": "Remove coverage artifacts",
      "command": "rm -rf .coverage"
    },
    "clean:target": {
      "description": "Remove target artifacts",
      "command": "rm -rf target"
    },
    "check": {
      "description": "Run format, lint, and type checks",
      "dependencies": [
        "check:dependencies",
        "check:format",
        "check:lint",
        "check:types"
      ]
    },
    "check:dependencies": {
      "description": "Verify dependencies and lockfile are in sync",
      "command": "deno install --frozen"
    },
    "check:format": {
      "description": "Validate code formatting",
      "command": "deno fmt --check"
    },
    "check:lint": {
      "description": "Run lint checks",
      "command": "deno lint"
    },
    "check:types": {
      "description": "Run type checking with plain deno check",
      "command": "deno check"
    },
    "security": {
      "description": "Run security checks",
      "dependencies": [
        "security:secrets",
        "security:vulnerabilities"
      ]
    },
    "security:secrets": {
      "description": "Scan repository and Git history for leaked credentials (requires gitleaks)",
      "dependencies": [
        "security:secrets:files",
        "security:secrets:history"
      ]
    },
    "security:secrets:files": {
      "description": "Scan working tree for leaked credentials (requires gitleaks)",
      "command": "gitleaks dir . --redact"
    },
    "security:secrets:history": {
      "description": "Scan Git history for leaked credentials (requires gitleaks)",
      "command": "gitleaks git . --redact"
    },
    "security:vulnerabilities": {
      "description": "Scan dependencies for known vulnerabilities",
      "command": "deno audit --frozen --level=high"
    },
    "setup": {
      "description": "Perform a repository setup",
      "dependencies": [
        "setup:dependencies",
        "setup:cog"
      ]
    },
    "setup:cog": {
      "description": "Install Cog-managed Git hooks into .git/hooks",
      "command": "cog install-hook --all --overwrite"
    },
    "setup:dependencies": {
      "description": "Install project dependencies into Deno cache",
      "command": "deno install"
    },
    "test": {
      "description": "Run test suite",
      "command": "deno test tests/ --coverage=.coverage --parallel --quiet --fail-fast --allow-all --permit-no-files"
    },
    "update": {
      "description": "Update dependencies within current semver ranges",
      "command": "deno outdated --update"
    },
    "update:interactive": {
      "description": "Interactively choose dependency updates",
      "command": "deno outdated --update --interactive"
    },
    "update:latest": {
      "description": "Update dependencies to latest versions (ignore current semver ranges)",
      "command": "deno outdated --update --latest"
    },
    "version": {
      "description": "Print package metadata from deno.json",
      "command": "deno eval \"const cfg = JSON.parse(await Deno.readTextFile('deno.json')); const rows = [['Name', cfg.name ?? ''], ['Version', cfg.version ?? ''], ['Description', cfg.description ?? '']]; const width = Math.max(...rows.map((row) => row[0].length)); console.log('Package metadata'); console.log('----------------'); for (const row of rows) { console.log(row[0].padEnd(width) + ' : ' + row[1]); }\""
    }
  },
  "exclude": [
    ".coverage/",
    "target/"
  ],
  "fmt": {
    "lineWidth": 120,
    "include": [
      "benchmarks/",
      "README.md",
      "src/",
      "tests/"
    ],
    "exclude": [
      ".coverage/",
      "target/"
    ]
  },
  "lint": {
    "include": [
      "benchmarks/",
      "src/",
      "tests/"
    ],
    "exclude": [
      ".coverage/",
      "target/"
    ]
  }
}
